  "keyFeatures": [
    "Multi-wiki farm supporting wikioasis.org and skywiki.org domains across two realms (production and beta)",
    "CentralAuth-based global accounts with strict mode and SUL3 support",
    "ManageWiki integration for self-service wiki creation and per-wiki configuration",
    "R2/S3 object storage with Cloudflare CDN delivery",
    "Per-wiki MediaWiki version management via WikiFarmMultiVersion",
    "Redis-backed caching with job queue and parser cache",
    "OpenSearch/CirrusSearch integration for full-text search",
    "Sentry error tracking and DogStatsD metrics",
    "Wikibase (repository and client) support with per-wiki entity namespaces",
    "Comprehensive permission system with disallowed rights and groups"
  ],
